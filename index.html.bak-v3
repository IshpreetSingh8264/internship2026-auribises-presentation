<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Ishpreet @ Auribises 2026</title>
<link rel="stylesheet" href="vendor/reveal/reveal.css">
<link rel="stylesheet" href="vendor/reveal/theme-black.css">
<style>
@font-face{font-family:'Bebas';src:url('vendor/fonts/BebasNeue-Regular.woff2') format('woff2');}
@font-face{font-family:'Jakarta';src:url('vendor/fonts/PlusJakarta-400.ttf') format('truetype');font-weight:400;}
@font-face{font-family:'Jakarta';src:url('vendor/fonts/PlusJakarta-700.ttf') format('truetype');font-weight:700;}
@font-face{font-family:'Mono';src:url('vendor/fonts/JetBrainsMono-400.ttf') format('truetype');font-weight:400;}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
.reveal-viewport{background:#0a0a0a!important;}
.reveal .slides{font-family:'Jakarta','Segoe UI',sans-serif;}
.reveal h1,.reveal h2,.reveal h3{text-transform:none;font-family:'Bebas','Impact',sans-serif;margin:0;}
.reveal .progress span{background:#FFD60A;}
.reveal .controls{color:#FFD60A;}
.reveal .slide-number{font-family:'Mono';color:#666;font-size:.68rem;}

/* ── CONSISTENT SLIDE TEMPLATE ─────────────── */
/* Every slide: sw > sh (header 46px) + sb (body flex:1) */
.sw{height:100%;display:flex;flex-direction:column;background:transparent;}
.sh{height:46px;padding:0 44px;display:flex;align-items:center;gap:14px;flex-shrink:0;border-bottom:1px solid rgba(255,255,255,0.08);}
.sh-n{font-family:'Mono';font-size:.65rem;color:#555;min-width:24px;}
.sh-t{font-family:'Bebas';font-size:1.2rem;letter-spacing:.5px;color:#f0f0f0;}
.sh-cat{margin-left:auto;font-family:'Mono';font-size:.62rem;color:#666;text-transform:uppercase;letter-spacing:.1em;}
.sb{flex:1;padding:20px 44px 18px;display:flex;min-height:0;overflow:hidden;}
.sb.split{flex-direction:row;gap:36px;align-items:center;}
.sb.center{flex-direction:column;align-items:center;justify-content:center;text-align:center;}
.sb.col{flex-direction:column;gap:12px;}

/* ── TYPE ──────────────────────────────────── */
.bb{font-family:'Bebas','Impact',sans-serif;line-height:.9;letter-spacing:1px;}
.mn{font-family:'Mono','Consolas',monospace;}
.d1{font-size:clamp(5rem,9vw,8.5rem);}
.d2{font-size:clamp(3.2rem,6vw,5.5rem);}
.d3{font-size:clamp(2rem,4vw,3.4rem);}
.d4{font-size:clamp(1.3rem,2.8vw,2rem);}
/* Projector-safe label: was #999, now #ccc */
.lbl{font-family:'Mono';font-size:.72rem;text-transform:uppercase;letter-spacing:.13em;color:#ccc;}
/* Body text readable on projector */
.body{font-size:1rem;line-height:1.6;color:#e0e0e0;}
.w{color:#f0f0f0;}.y{color:#FFD60A;}.r{color:#FF3B30;}.b{color:#0A84FF;}
.o{color:#FF6B2B;}.v{color:#BF5AF2;}.g{color:#32D74B;}.p{color:#FF375F;}.t{color:#32ADE6;}

/* ── PROJECTOR-SAFE CARDS ──────────────────── */
/* Solid colored backgrounds — visible on dim projectors */
.card{border-radius:10px;padding:16px 18px;}
.card-y{background:#FFD60A;color:#111;}
.card-r{background:#FF3B30;color:#fff;}
.card-b{background:#0A84FF;color:#fff;}
.card-o{background:#FF6B2B;color:#fff;}
.card-g{background:#32D74B;color:#111;}
.card-v{background:#9333ea;color:#fff;}
.card-p{background:#FF375F;color:#fff;}
.card-t{background:#0891b2;color:#fff;}
/* Dark card with visible border (projector-safe: 3px border) */
.card-dk{background:#1a1a1a;border:2px solid rgba(255,255,255,0.18);border-radius:10px;padding:16px 18px;}

/* ── STAT BOX ──────────────────────────────── */
.stat{border-radius:10px;padding:18px 16px;text-align:center;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.stat-n{font-family:'Bebas';line-height:.9;}
/* Projector-safe label inside stat: use dark color on bright bg */
.stat-l{font-family:'Mono';font-size:.68rem;text-transform:uppercase;letter-spacing:.08em;margin-top:6px;line-height:1.3;}

/* ── FEATURE ROW (replaces bullets) ────────── */
.feat{display:flex;flex-direction:column;gap:8px;width:100%;}
.fr{display:flex;align-items:center;gap:12px;padding:10px 13px;border-radius:7px;background:#1f1f1f;border-left:4px solid;}
.fr-icon{width:30px;height:30px;border-radius:5px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:.95rem;}
.fr-text{font-size:.92rem;color:#e8e8e8;font-family:'Jakarta';line-height:1.35;}
.fr-text strong{color:#fff;}

/* ── ARCH DIAGRAM HTML — SOLID ACCENT CARDS ── */
/* Each layer is a fully-colored card; nodes are white pills inside */
.arch{display:flex;flex-direction:column;gap:6px;width:100%;}
.al{border-radius:8px;padding:11px 14px;display:flex;flex-direction:column;gap:8px;}
.al-lbl{font-family:'Bebas';font-size:.92rem;text-transform:uppercase;letter-spacing:.12em;color:#fff;line-height:1;display:flex;align-items:center;gap:7px;}
.al-lbl::before{content:"";display:inline-block;width:8px;height:8px;border-radius:50%;background:#fff;flex-shrink:0;}
.an-row{display:flex;gap:6px;flex-wrap:wrap;}
.an{padding:5px 12px;border-radius:14px;font-family:'Jakarta','Segoe UI',sans-serif;font-size:.8rem;border:none;font-weight:700;background:#fff;line-height:1.3;}
.aconn{text-align:center;font-family:'Mono';font-size:.78rem;color:#bbb;padding:3px 0;font-weight:700;letter-spacing:.05em;}

/* ── BENTO TILES — asymmetric, full-screen ──── */
.bento-grid{display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;grid-template-rows:1fr 1fr .55fr;gap:10px;flex:1;width:100%;min-height:0;}
.tile{border-radius:11px;padding:16px 18px;display:flex;flex-direction:column;position:relative;overflow:hidden;min-height:0;}
.t-hero{padding:22px 24px;grid-row:1/3;}
.t-num{position:absolute;top:13px;right:15px;font-family:'Mono';font-size:.65rem;color:rgba(0,0,0,.5);text-transform:uppercase;letter-spacing:.12em;font-weight:700;}
.tile-dark .t-num{color:rgba(255,255,255,.6);}
.t-icon{width:38px;height:38px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-bottom:10px;}
.t-hero .t-icon{width:54px;height:54px;margin-bottom:14px;}
.t-name{font-family:'Bebas';font-size:1.75rem;line-height:.95;letter-spacing:.5px;color:#000;}
.tile-dark .t-name{color:#fff;}
.t-hero .t-name{font-size:3.2rem;line-height:.9;color:#fff;}
.t-sub{font-size:.78rem;color:rgba(0,0,0,.78);margin-top:6px;font-family:'Jakarta';font-weight:700;line-height:1.3;}
.tile-dark .t-sub{color:rgba(255,255,255,.88);}
.t-stat{margin-top:auto;padding-top:8px;border-top:1.5px solid rgba(0,0,0,.18);font-family:'Mono';font-size:.66rem;font-weight:700;letter-spacing:.03em;color:rgba(0,0,0,.72);text-transform:uppercase;line-height:1.3;}
.tile-dark .t-stat{border-top-color:rgba(255,255,255,.22);color:rgba(255,255,255,.88);}
.t-hero-stat{font-family:'Bebas';font-size:5.2rem;line-height:.85;color:#fff;margin:6px 0 4px;}
.t-hero-stat-l{font-family:'Mono';font-size:.7rem;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.88);font-weight:700;}

/* Timeline strip (bottom row, spans full width) */
.timeline-strip{grid-column:1/5;display:flex;align-items:center;gap:14px;padding:14px 22px;background:#141414;border:2px solid rgba(255,255,255,.12);border-radius:11px;}
.tl-rail{flex:1;display:flex;align-items:center;justify-content:space-between;position:relative;}
.tl-rail::before{content:'';position:absolute;top:50%;left:2%;right:2%;height:2px;background:linear-gradient(90deg,#FFD60A 0%,#32D74B 100%);transform:translateY(-50%);border-radius:1px;}
.tl-mk{flex:1;display:flex;flex-direction:column;align-items:center;position:relative;z-index:1;}
.tl-dot{width:18px;height:18px;border-radius:50%;background:#0a0a0a;border:2.5px solid #FFD60A;display:flex;align-items:center;justify-content:center;font-family:'Bebas';font-size:.7rem;color:#FFD60A;font-weight:700;}
.tl-mk.done .tl-dot{background:#FFD60A;color:#0a0a0a;border-color:#FFD60A;}
.tl-mk.done .tl-mlabel{color:#FFD60A;}
.tl-mlabel{font-family:'Mono';font-size:.58rem;color:#666;text-transform:uppercase;letter-spacing:.08em;margin-top:5px;font-weight:700;}
.tl-divider{width:1px;height:36px;background:rgba(255,255,255,.15);}
.tl-stat{display:flex;flex-direction:column;align-items:flex-start;min-width:120px;}
.tl-stat-n{font-family:'Bebas';font-size:1.8rem;line-height:.9;color:#FFD60A;letter-spacing:1px;}
.tl-stat-l{font-family:'Mono';font-size:.6rem;color:#888;text-transform:uppercase;letter-spacing:.1em;margin-top:3px;font-weight:700;}

/* ── FLOW — solid accent chips for projector ── */
.flow{display:flex;align-items:center;gap:8px;flex-wrap:wrap;align-items:center;}
.fn{padding:7px 14px;border-radius:14px;font-family:'Jakarta','Segoe UI',sans-serif;font-size:.82rem;border:none;white-space:nowrap;font-weight:700;line-height:1.2;}
.fa{color:#FFD60A;font-size:1.1rem;font-weight:900;}

/* ── DRAKE MEME ────────────────────────────── */
.drake-wrap{display:flex;flex-direction:column;border-radius:10px;overflow:hidden;width:100%;}
.dp{display:flex;align-items:center;min-height:90px;}
.dp-face{width:105px;flex-shrink:0;display:flex;align-items:center;justify-content:center;padding:8px;}
.dp-text{flex:1;padding:12px 16px;font-family:'Jakarta';font-size:.93rem;font-weight:700;line-height:1.3;}
.dp.no{background:#2a1414;}.dp.no .dp-text{color:#ff8080;}
.dp.yes{background:#142a14;}.dp.yes .dp-text{color:#80ff90;}
.dp.woj{background:#14141c;}.dp.woj .dp-text{color:#a0a0cc;}

/* ── BRAIN MEME ────────────────────────────── */
.bm{display:flex;flex-direction:column;gap:6px;width:100%;}
.br{display:flex;align-items:center;gap:16px;padding:11px 14px;border-radius:8px;border:2px solid rgba(255,255,255,0.08);}
.br-face{width:54px;flex-shrink:0;display:flex;align-items:center;justify-content:center;}
.br-text{font-family:'Jakarta';font-size:.9rem;color:#e0e0e0;line-height:1.3;flex:1;}

/* ── TERMINAL ──────────────────────────────── */
.term{background:#141414;border:2px solid #2a2a2a;border-radius:9px;padding:18px 22px;font-family:'Mono';font-size:.79rem;line-height:1.85;width:100%;}
.tc{color:#888;}.tk{color:#4da6ff;}.tv{color:#4dff88;}.td{color:#777;}

/* ── ANIMATIONS ────────────────────────────── */
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
@keyframes wave{from{transform:rotate(-18deg)}to{transform:rotate(14deg)}}
@keyframes fireFlicker{0%,100%{transform:scaleY(1)}50%{transform:scaleY(1.08)}}
@keyframes confetti-fall{0%{transform:translateY(-10px) rotate(0deg);opacity:1;}100%{transform:translateY(750px) rotate(600deg);opacity:0;}}
.float-anim{animation:float 4s ease-in-out infinite;}
.wave-arm{transform-origin:146px 153px;animation:wave .65s ease-in-out infinite alternate;}
.confetti-piece{position:absolute;pointer-events:none;z-index:20;animation:confetti-fall linear;}
.gsap-up{opacity:0;transform:translateY(24px);}
.gsap-right{opacity:0;transform:translateX(-24px);}
.gsap-scale{opacity:0;transform:scale(.82);}
</style>
</head>
<body>
<div class="reveal"><div class="slides">

<!-- ═══ S01 TITLE ════════════════════════════════════ -->
<section data-background-color="#0a0a0a">
<div class="sw">
  <div class="sh" style="border-color:rgba(255,214,10,.2);">
    <span class="sh-n" style="color:#FFD60A;">00</span>
    <span class="sh-t" style="color:#FFD60A;">INTERNSHIP REPORT 2026</span>
    <span class="sh-cat">Auribises Technologies</span>
  </div>
  <div class="sb split" style="gap:0;padding:16px 44px;">
    <!-- LEFT: text -->
    <div style="flex:1.1;display:flex;flex-direction:column;justify-content:center;gap:8px;">
      <div class="lbl gsap-right" style="color:#FFD60A;">GNDPC Ludhiana · Computer Science &amp; Engineering</div>
      <div class="bb d1 w gsap-right" style="line-height:.88;">INTERNSHIP</div>
      <div class="bb d1 y gsap-right" style="line-height:.88;margin-top:-4px;">REPORT</div>
      <div style="height:3px;width:100%;background:linear-gradient(90deg,#FFD60A,transparent);margin:12px 0 10px;"></div>
      <div class="bb d4 w gsap-right" style="letter-spacing:2px;opacity:.85;">AT AURIBISES TECHNOLOGIES</div>
      <div class="mn gsap-right" style="font-size:.8rem;color:#666;margin-top:4px;">JANUARY 2026 — JUNE 2026</div>
      <div style="margin-top:20px;display:flex;flex-direction:column;gap:5px;">
        <div class="lbl gsap-up" style="color:#ccc;">Ishpreet Singh · CSE · Roll 1030 · Reg 230179501386</div>
        <div class="lbl gsap-up" style="color:#777;">Mentor: Aman Bhardawaj · Supervisor: Ishant Kumar (Auribises)</div>
      </div>
    </div>
    <!-- RIGHT: Sikh developer SVG -->
    <div style="flex:.9;display:flex;align-items:center;justify-content:center;">
      <div class="gsap-scale float-anim">
        <svg viewBox="0 0 240 370" width="275" xmlns="http://www.w3.org/2000/svg">
          <!-- Laptop -->
          <rect x="10" y="268" width="220" height="88" rx="10" fill="#1c2030"/>
          <rect x="18" y="276" width="204" height="70" rx="5" fill="#0d1117"/>
          <rect x="28" y="286" width="60" height="4" rx="2" fill="#22d3ee"/>
          <rect x="38" y="296" width="46" height="4" rx="2" fill="#86efac"/>
          <rect x="38" y="306" width="76" height="4" rx="2" fill="#fca5a5"/>
          <rect x="28" y="316" width="35" height="4" rx="2" fill="#22d3ee"/>
          <rect x="28" y="326" width="52" height="4" rx="2" fill="#f9a8d4"/>
          <rect x="88" y="286" width="3" height="11" rx="1" fill="#22d3ee"><animate attributeName="opacity" values="1;0;1" dur="1.1s" repeatCount="indefinite"/></rect>
          <rect x="10" y="354" width="220" height="7" rx="3" fill="#2a3040"/>
          <!-- Body -->
          <rect x="65" y="196" width="110" height="76" rx="16" fill="#2563eb"/>
          <rect x="80" y="208" width="22" height="14" rx="3" fill="#1d4ed8"/>
          <!-- Neck -->
          <rect x="107" y="186" width="26" height="15" rx="7" fill="#E8C8A0"/>
          <!-- Face base behind source character -->
          <circle cx="120" cy="160" r="44" fill="#E8C8A0"/>
          <!-- === SOURCE: face + turban, scaled ×3.5, recoloured === -->
          <g transform="translate(36,58) scale(3.5)">
            <!-- Turban main body (st11) -->
            <path d="M24,5C15.9,5,9.4,11.5,9.4,19.6v7.6h29.2v-7.6C38.6,11.5,32.1,5,24,5z" fill="#666666" stroke="#444444" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
            <!-- Face contour (st11, recoloured from grey to skin) -->
            <path d="M40.2,26.1c-0.1-1.1-1-2-2.1-2.3l-0.9-0.2C35.9,23.2,35,22,35,20.7v-3.1c0-1.3-0.9-2.4-2.1-2.7c-2.3,1-5.4,1.6-8.9,1.6s-6.6-0.6-8.9-1.6c-1.2,0.3-2.1,1.4-2.1,2.7v3.1c0,1.4-0.9,2.6-2.2,2.9l-0.9,0.2c-1.1,0.3-2,1.2-2.1,2.3c-0.1,1.6,1.1,2.9,2.7,2.9c0.1,0,0.1,0,0.2,0c1,6.5,6.5,11.5,13.3,11.5s12.3-5,13.3-11.5c0.1,0,0.1,0,0.2,0C39,29.1,40.3,27.7,40.2,26.1z" fill="#E8C8A0" stroke="none"/>
            <!-- Eyes (st12) -->
            <circle cx="17.1" cy="25.8" r="1.1" fill="#444444"/>
            <circle cx="30.9" cy="25.8" r="1.1" fill="#444444"/>
            <!-- Smile (st3) -->
            <path d="M21.2,36.1c0,0,0.7,0.9,2.8,0.9c2.1,0,2.8-0.9,2.8-0.9" fill="none" stroke="#444444" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
            <!-- Back hair / top lightening (st82) -->
            <path d="M39.4,16.7c0-0.8,0-1.8,0-2.8c0-6.9-6.6-12.2-15.4-12.2S8.6,6.9,8.6,13.8C8.6,22.7,9.4,24,9.4,24s6.9-3.4,15-5.4c8.3,1.9,14.2,5.3,14.2,5.3S39.2,23,39.4,16.7z" fill="#777777"/>
            <!-- White highlight (st41) -->
            <path d="M24,5.7c8.4,0,14.8,4.8,15.4,11.2c0-0.1,0-0.2,0-0.3c0-0.8,0-1.8,0-2.8c0-6.9-6.6-12.2-15.4-12.2S8.6,6.9,8.6,13.8c0,1.2,0,2.2,0,3.2C9.2,10.5,15.6,5.7,24,5.7z" fill="#FFFFFF"/>
            <!-- Turban outline & hair detail lines (st3) -->
            <path d="M39.4,16.7c0-0.8,0-1.8,0-2.8c0-6.9-6.6-12.2-15.4-12.2S8.6,6.9,8.6,13.8C8.6,22.7,9.4,24,9.4,24s6.9-3.4,15-5.4c8.3,1.9,14.2,5.3,14.2,5.3S39.2,23,39.4,16.7z" fill="none" stroke="#444444" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M8.6,13.8c0,0,5.8-10.5,22.3-11" fill="none" stroke="#444444" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M35.4,11.9c0,0-11.7-0.2-22.1,6.6" fill="none" stroke="#444444" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M24.4,18.6c10.5-2.5,15-2,15-2" fill="none" stroke="#444444" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
          </g>
          <!-- Custom features: eyebrows, nose, moustache, beard -->
          <path d="M 88 142 Q 96 138 104 142" stroke="#3a2418" stroke-width="1.8" fill="none" stroke-linecap="round"/>
          <path d="M 136 142 Q 144 138 152 142" stroke="#3a2418" stroke-width="1.8" fill="none" stroke-linecap="round"/>
          <ellipse cx="120" cy="148" rx="3.5" ry="2.5" fill="#D4B08A"/>
          <path d="M 117 150 Q 120 152 123 150" stroke="#B8946A" stroke-width="0.8" fill="none" stroke-linecap="round"/>
          <path d="M 100 164 Q 115 160 120 162 Q 125 160 140 164" stroke="#5a3a1a" stroke-width="2.5" fill="#5a3a1a" stroke-linecap="round"/>
          <path d="M 85 176 Q 95 168 108 172 Q 120 176 132 172 Q 145 168 155 176 Q 152 192 144 200 Q 130 206 120 206 Q 110 206 96 200 Q 88 192 85 176 Z" fill="#5a3a1a"/>
          <path d="M 95 187 Q 100 192 103 196" stroke="#3a2418" stroke-width="0.8" fill="none" stroke-linecap="round" opacity=".4"/>
          <path d="M 145 187 Q 140 192 137 196" stroke="#3a2418" stroke-width="0.8" fill="none" stroke-linecap="round" opacity=".4"/>
          <!-- Arms (skin coloured) -->
          <path d="M 65 213 Q 37 234 34 268" stroke="#E8C8A0" stroke-width="19" stroke-linecap="round" fill="none"/>
          <path d="M 175 213 Q 203 234 206 268" stroke="#E8C8A0" stroke-width="19" stroke-linecap="round" fill="none"/>
        </svg>
        </svg>
      </div>
    </div>
  </div>
</div>
</section>

<!-- ═══ S02 WHO AM I ══════════════════════════════════ -->
<section data-background-color="#0a0a0a">
<div class="sw">
  <div class="sh">
    <span class="sh-n">01</span>
    <span class="sh-t">WHO AM I</span>
    <span class="sh-cat">About</span>
  </div>
  <div class="sb split">
    <!-- LEFT -->
    <div style="flex:1.1;display:flex;flex-direction:column;gap:14px;">
      <div>
        <div class="bb d3 w">THE DEVELOPER<br><span class="y">BEHIND THE WORK</span></div>
        <div style="height:3px;width:56px;background:#FFD60A;border-radius:2px;margin:12px 0;"></div>
      </div>
      <p class="body" style="font-size:.97rem;">2+ years of self-taught full-stack before this internship. React, Firebase, Python, Flutter — I already knew the tools. At Auribises, I learned what they mean at <strong>production scale</strong> with real clients, real regulations, and real consequences.</p>
      <!-- Feature rows instead of bullets -->
      <div class="feat">
        <div class="fr" style="border-color:#FFD60A;">
          <div class="fr-icon" style="background:#FFD60A55;">⚡</div>
          <div class="fr-text"><strong>Before:</strong> Hobby projects, local servers, YouTube tutorials</div>
        </div>
        <div class="fr" style="border-color:#32D74B;">
          <div class="fr-icon" style="background:#32D74B55;">🚀</div>
          <div class="fr-text"><strong>After:</strong> Production systems serving users in India and Germany</div>
        </div>
        <div class="fr" style="border-color:#0A84FF;">
          <div class="fr-icon" style="background:#0A84FF55;">🔬</div>
          <div class="fr-text"><strong>Domain:</strong> Full-stack · AI/ML · IoT · Mobile · DevOps · Enterprise</div>
        </div>
      </div>
    </div>
    <!-- RIGHT: stats + giga chad -->
    <div style="flex:.85;display:flex;flex-direction:column;gap:9px;">
      <!-- Giga Chad -->
