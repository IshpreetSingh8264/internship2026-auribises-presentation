        <!-- Body -->
        <rect x="54" y="154" width="92" height="60" rx="14" fill="#2563eb"/>
        <!-- Neck -->
        <rect x="88" y="146" width="24" height="14" rx="7" fill="#E8C8A0"/>
        <!-- Face base behind source character -->
        <circle cx="100" cy="118" r="38" fill="#E8C8A0"/>
        <!-- === SOURCE: face + turban, scaled for S16 === -->
        <g transform="translate(33,45) scale(2.8)">
          <path d="M24,5C15.9,5,9.4,11.5,9.4,19.6v7.6h29.2v-7.6C38.6,11.5,32.1,5,24,5z" fill="#666666" stroke="#444444" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M40.2,26.1c-0.1-1.1-1-2-2.1-2.3l-0.9-0.2C35.9,23.2,35,22,35,20.7v-3.1c0-1.3-0.9-2.4-2.1-2.7c-2.3,1-5.4,1.6-8.9,1.6s-6.6-0.6-8.9-1.6c-1.2,0.3-2.1,1.4-2.1,2.7v3.1c0,1.4-0.9,2.6-2.2,2.9l-0.9,0.2c-1.1,0.3-2,1.2-2.1,2.3c-0.1,1.6,1.1,2.9,2.7,2.9c0.1,0,0.1,0,0.2,0c1,6.5,6.5,11.5,13.3,11.5s12.3-5,13.3-11.5c0.1,0,0.1,0,0.2,0C39,29.1,40.3,27.7,40.2,26.1z" fill="#E8C8A0" stroke="none"/>
          <circle cx="17.1" cy="25.8" r="1.1" fill="#444444"/>
          <circle cx="30.9" cy="25.8" r="1.1" fill="#444444"/>
          <path d="M21.2,36.1c0,0,0.7,0.9,2.8,0.9c2.1,0,2.8-0.9,2.8-0.9" fill="none" stroke="#444444" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M39.4,16.7c0-0.8,0-1.8,0-2.8c0-6.9-6.6-12.2-15.4-12.2S8.6,6.9,8.6,13.8C8.6,22.7,9.4,24,9.4,24s6.9-3.4,15-5.4c8.3,1.9,14.2,5.3,14.2,5.3S39.2,23,39.4,16.7z" fill="#777777"/>
          <path d="M24,5.7c8.4,0,14.8,4.8,15.4,11.2c0-0.1,0-0.2,0-0.3c0-0.8,0-1.8,0-2.8c0-6.9-6.6-12.2-15.4-12.2S8.6,6.9,8.6,13.8c0,1.2,0,2.2,0,3.2C9.2,10.5,15.6,5.7,24,5.7z" fill="#FFFFFF"/>
          <path d="M39.4,16.7c0-0.8,0-1.8,0-2.8c0-6.9-6.6-12.2-15.4-12.2S8.6,6.9,8.6,13.8C8.6,22.7,9.4,24,9.4,24s6.9-3.4,15-5.4c8.3,1.9,14.2,5.3,14.2,5.3S39.2,23,39.4,16.7z" fill="none" stroke="#444444" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M8.6,13.8c0,0,5.8-10.5,22.3-11" fill="none" stroke="#444444" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M35.4,11.9c0,0-11.7-0.2-22.1,6.6" fill="none" stroke="#444444" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M24.4,18.6c10.5-2.5,15-2,15-2" fill="none" stroke="#444444" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
        </g>
        <!-- Custom features: eyebrows, nose, moustache, beard -->
