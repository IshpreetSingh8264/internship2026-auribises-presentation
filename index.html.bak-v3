    <div style="flex:1;display:flex;flex-direction:column;gap:10px;">
      <div class="lbl" style="color:#666;margin-bottom:2px;">a tale of two developers</div>
      <div class="drake-wrap" style="border:2px solid #222;">
        <div class="dp no"><div class="dp-face" style="background:#1c0808;">
          <svg viewBox="0 0 70 80" width="78"><circle cx="35" cy="35" r="24" fill="#C8924A"/><path d="M 13 22 Q 35 8 57 22 L 55 13 Q 35 0 15 13Z" fill="#1c1917"/><circle cx="44" cy="30" r="4.5" fill="#1c1917"/><path d="M 29 47 Q 39 42 49 46" stroke="#7a3000" stroke-width="2" fill="none"/><ellipse cx="57" cy="66" rx="11" ry="8" fill="#C8924A"/><rect x="50" y="57" width="8" height="7" rx="3" fill="#C8924A"/><rect x="55" y="54" width="7" height="6" rx="3" fill="#C8924A"/></svg>
        </div><div class="dp-text">Following tutorials. Building todo apps. Writing code that only runs on my laptop.</div></div>
        <div class="dp yes" style="border-top:1px solid #1a1a1a;"><div class="dp-face" style="background:#081c08;">
          <svg viewBox="0 0 70 80" width="78"><circle cx="35" cy="35" r="24" fill="#C8924A"/><path d="M 12 22 Q 35 8 58 22 L 56 12 Q 35 -1 14 12Z" fill="#1c1917"/><circle cx="27" cy="31" r="4.5" fill="#1c1917"/><circle cx="43" cy="31" r="4.5" fill="#1c1917"/><circle cx="29" cy="29" r="2" fill="white"/><circle cx="45" cy="29" r="2" fill="white"/><path d="M 26 46 Q 35 54 44 48" stroke="#7a3000" stroke-width="2.2" fill="none"/><line x1="52" y1="62" x2="72" y2="56" stroke="#C8924A" stroke-width="8" stroke-linecap="round"/><circle cx="73" cy="55" r="5" fill="#C8924A"/></svg>
        </div><div class="dp-text">Shipping GDPR-compliant German healthcare software, live IoT security systems, and AI textile intelligence to real production.</div></div>
        <div class="dp woj" style="border-top:1px solid #1a1a1a;"><div class="dp-face" style="background:#10101a;">
          <svg viewBox="0 0 70 80" width="78"><circle cx="35" cy="40" r="28" fill="#E8D5C0"/><path d="M 10 27 Q 35 10 60 27 L 58 18 Q 35 4 12 18Z" fill="#5a3a1a"/><ellipse cx="6" cy="42" rx="6" ry="10" fill="#E0C8B0"/><ellipse cx="64" cy="42" rx="6" ry="10" fill="#E0C8B0"/><path d="M 20 34 Q 27 27 34 34 Q 27 31 20 34Z" fill="#1c1917"/><path d="M 36 34 Q 43 27 50 34 Q 43 31 36 34Z" fill="#1c1917"/><path d="M 22 42 Q 18 52 20 60" stroke="#60a0ff" stroke-width="2.5" fill="none" stroke-linecap="round"/><path d="M 48 42 Q 52 52 50 60" stroke="#60a0ff" stroke-width="2.5" fill="none" stroke-linecap="round"/><path d="M 24 64 Q 35 58 46 64" stroke="#9a7060" stroke-width="2.2" fill="none" stroke-linecap="round"/></svg>
        </div><div class="dp-text">me at 11pm reading GSAP docs to animate this very presentation</div></div>
      </div>
    </div>
    <!-- This is Fine dog -->
    <div style="flex:.85;display:flex;flex-direction:column;align-items:center;gap:10px;">
      <div class="lbl" style="color:#666;">me debugging SAP at 2am</div>
      <svg viewBox="0 0 280 234" width="270" xmlns="http://www.w3.org/2000/svg">
