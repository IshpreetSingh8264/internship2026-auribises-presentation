        <path d="M 144 115 Q 151 110 158 115" stroke="#1c1917" stroke-width="2.2" fill="none" stroke-linecap="round"/>
        <ellipse cx="140" cy="127" rx="6" ry="4.5" fill="#1c1917"/>
