        <path d="M 113 111 Q 120 108 127 111" stroke="#3a2418" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <ellipse cx="100" cy="125" rx="3" ry="2" fill="#D4B08A"/>
        <path d="M 84 138 Q 96 135 100 137 Q 104 135 116 138" stroke="#5a3a1a" stroke-width="2.2" fill="#5a3a1a" stroke-linecap="round"/>
        <path d="M 70 146 Q 80 139 90 143 Q 100 146 110 143 Q 120 139 130 146 Q 128 160 120 166 Q 110 170 100 170 Q 90 170 80 166 Q 72 160 70 146 Z" fill="#5a3a1a"/>
        <path d="M 78 155 Q 83 160 85 163" stroke="#3a2418" stroke-width="0.7" fill="none" stroke-linecap="round" opacity=".4"/>
        <path d="M 122 155 Q 117 160 115 163" stroke="#3a2418" stroke-width="0.7" fill="none" stroke-linecap="round" opacity=".4"/>
        <!-- Left arm static -->
        <path d="M 54 168 Q 30 184 28 210" stroke="#E8C8A0" stroke-width="17" stroke-linecap="round" fill="none"/>
        <!-- Right arm WAVING -->
        <path class="wave-arm" d="M 146 165 Q 168 156 182 138" stroke="#E8C8A0" stroke-width="17" stroke-linecap="round" fill="none"/>
      </svg>
    </div>
  </div>
</div>
</section>

</div></div>
<script src="vendor/reveal/reveal.js"></script>
<script src="vendor/reveal/plugins/notes/notes.js"></script>
<script src="vendor/gsap.min.js"></script>
<script>
Reveal.initialize({
  hash:true, slideNumber:'c/t',
  transition:'fade', transitionSpeed:'default', backgroundTransition:'fade',
  center:false, width:1200, height:680, margin:.03, minScale:.2, maxScale:2.5,
  controls:true, progress:true, keyboard:true,
  autoAnimate:true, autoAnimateEasing:'cubic-bezier(0.25,0.1,0.25,1)',
  autoAnimateDuration:.4, autoAnimateUnmatched:'fade',
  plugins:[RevealNotes],
});

function animateCounter(el,target,dur){
  const isFloat=String(target).includes('.');
  const obj={val:0};
  gsap.to(obj,{val:target,duration:dur||1.4,ease:'power3.out',
    onUpdate:()=>{el.textContent=isFloat?obj.val.toFixed(1):Math.round(obj.val).toLocaleString();}});
}

function spawnConfetti(slide){
  const cols=['#FFD60A','#FF3B30','#0A84FF','#32D74B','#9333ea','#FF375F','#FF6B2B'];
  for(let i=0;i<40;i++){
    const p=document.createElement('div');
    p.className='confetti-piece';
    const s=Math.random()*10+5;
    p.style.cssText=`width:${s}px;height:${s}px;background:${cols[i%cols.length]};`+
      `left:${Math.random()*100}%;top:-20px;`+
      `border-radius:${Math.random()>.5?'50%':'3px'};`+
      `animation-duration:${Math.random()*2.5+1.8}s;animation-delay:${Math.random()*1.5}s;`;
    slide.appendChild(p);
  }
}

function runAnim(slide,idx){
  // Slide content wipe-in
  const sl=slide.querySelector('.sb');
  if(sl) gsap.fromTo(sl,{clipPath:'inset(0 100% 0 0)'},{clipPath:'inset(0 0% 0 0)',duration:.5,ease:'power2.inOut',clearProps:'clipPath'});

  // Generic entrances
  const rights=slide.querySelectorAll('.gsap-right');
  if(rights.length) gsap.fromTo(rights,{opacity:0,x:-26},{opacity:1,x:0,duration:.55,stagger:.09,ease:'power2.out'});
  const ups=slide.querySelectorAll('.gsap-up');
  if(ups.length) gsap.fromTo(ups,{opacity:0,y:20},{opacity:1,y:0,duration:.5,stagger:.09,delay:.28,ease:'power2.out'});
  const scales=slide.querySelectorAll('.gsap-scale');
  if(scales.length) gsap.fromTo(scales,{opacity:0,scale:.8},{opacity:1,scale:1,duration:.65,delay:.1,ease:'back.out(1.4)'});

  // Counters
  slide.querySelectorAll('[data-count]').forEach(el=>animateCounter(el,parseFloat(el.dataset.count)));

  // Bento tiles
  if(idx===3){
    gsap.fromTo(slide.querySelectorAll('.tile'),{opacity:0,scale:.86,y:14},{opacity:1,scale:1,y:0,duration:.44,stagger:.055,ease:'back.out(1.3)'});
    gsap.fromTo(slide.querySelector('.timeline-strip'),{opacity:0,y:18},{opacity:1,y:0,duration:.5,delay:.42,ease:'power2.out'});
    gsap.fromTo(slide.querySelectorAll('.tl-mk'),{opacity:0,scale:.4},{opacity:1,scale:1,duration:.32,stagger:.06,delay:.55,ease:'back.out(1.6)'});
    gsap.fromTo(slide.querySelectorAll('.tl-stat'),{opacity:0,x:-12},{opacity:1,x:0,duration:.4,stagger:.08,delay:.6,ease:'power2.out'});
  }

  // Project slides: arch nodes + feature rows stagger
  if(idx>=4&&idx<=10){
    gsap.fromTo(slide.querySelectorAll('.an'),{opacity:0,x:-12},{opacity:1,x:0,duration:.3,stagger:.04,delay:.18,ease:'power2.out'});
    gsap.fromTo(slide.querySelectorAll('.fr'),{opacity:0,y:14},{opacity:1,y:0,duration:.38,stagger:.08,delay:.3,ease:'power2.out'});
    const stats=slide.querySelectorAll('.stat');
    gsap.fromTo(stats,{opacity:0,scale:.75},{opacity:1,scale:1,duration:.44,stagger:.1,delay:.32,ease:'back.out(1.7)'});
  }

  // Metrics: all stat cards pop
  if(idx===12) gsap.fromTo(slide.querySelectorAll('.stat'),{opacity:0,y:26,scale:.88},{opacity:1,y:0,scale:1,duration:.44,stagger:.09,ease:'back.out(1.4)'});

  // Brain rows slide in
  if(idx===13) gsap.fromTo(slide.querySelectorAll('.br'),{opacity:0,x:-32},{opacity:1,x:0,duration:.52,stagger:.18,ease:'power2.out'});

  // Drake panels
  if(idx===14) gsap.fromTo(slide.querySelectorAll('.dp'),{opacity:0,x:-24},{opacity:1,x:0,duration:.5,stagger:.22,ease:'power2.out'});

  // Terminal lines
  if(idx===11) gsap.fromTo(slide.querySelectorAll('.term > div'),{opacity:0,x:-10},{opacity:1,x:0,duration:.26,stagger:.05,ease:'none'});

  // Thank you: big text + confetti
  if(idx===15){
    gsap.fromTo(slide.querySelectorAll('.bb'),{opacity:0,y:34,skewX:-2},{opacity:1,y:0,skewX:0,duration:.65,stagger:.12,ease:'power3.out'});
    setTimeout(()=>spawnConfetti(slide),500);
  }

  // Who am I: stat cards
  if(idx===1) gsap.fromTo(slide.querySelectorAll('.stat'),{opacity:0,scale:.82},{opacity:1,scale:1,duration:.4,stagger:.09,delay:.3,ease:'back.out(1.4)'});
}

Reveal.on('ready',({currentSlide})=>runAnim(currentSlide,0));
Reveal.on('slidechanged',({currentSlide,indexh})=>runAnim(currentSlide,indexh));
</script>
</body></html>
