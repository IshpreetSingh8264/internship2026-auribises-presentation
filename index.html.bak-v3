        <rect x="124" y="150" width="26" height="18" rx="3" fill="white" stroke="#9c6010" stroke-width="1.8"/>
        <path d="M 150 155 Q 157 155 157 162 Q 157 169 150 169" stroke="#9c6010" stroke-width="1.8" fill="none"/>
        <path d="M 130 148 Q 132 142 130 136" stroke="#bbb" stroke-width="1.5" fill="none" stroke-linecap="round"/>
